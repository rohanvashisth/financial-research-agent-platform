# Execution Mode: 'local' (uses SQLite & In-Memory events) or 'production' (uses Postgres/pgvector & Kafka)
RUN_MODE=local

# Google Gemini API Key
GEMINI_API_KEY=

# SEC Edgar User-Agent (Required by SEC: "Company Name contact@email.com")
SEC_USER_AGENT=FinancialResearchAgent/1.0 (researcher@example.com)

# Database Configuration (for Production Mode)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=financial_research
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Kafka Configuration (for Production Mode)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Server Ports
PORT=8000
FRONTEND_URL=http://localhost:5173
